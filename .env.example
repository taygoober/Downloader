# Environment variables for the Video Downloader backend
# Copy this file to .env and adjust as needed

# Port to expose the API on (default: 8000)
PORT=8000

# Absolute path where downloaded files are stored inside the container
DOWNLOADS_DIR=/app/downloads

# Comma-separated list of allowed CORS origins.
# Use * to allow all (suitable for local/LAN use).
# Example: ALLOWED_ORIGINS=https://myserver.com,http://192.168.1.100:8000
ALLOWED_ORIGINS=*
